# Telegram delivery for the /start-project inquiry form.
# Copy to .env.local and fill with real values (never commit .env.local).

# Bot token from @BotFather (format: 123456789:ABC-DEF...). Server-only secret.
TELEGRAM_BOT_TOKEN=

# Destination chat id the lead summary is sent to (user, group, or channel id).
TELEGRAM_CHAT_ID=

# Upstash Redis (REST) — backs the /api/telegram rate limiter (5 req / 10 min per IP).
# From the Upstash console → your KV database → REST API. Server-only secrets.
# Note the KV-prefixed names — the code reads these exact keys, not the unprefixed ones.
UPSTASH_REDIS_REST_KV_REST_API_URL=
UPSTASH_REDIS_REST_KV_REST_API_TOKEN=
